<Window x:Class="Character_Animator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Character_Animator"
        mc:Ignorable="d"
        Title="Creatures of Kernow Animation Editor" Height="600" Width="1200" ResizeMode="NoResize">
    <DockPanel>
        <!-- Top bar docked to top -->
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="10">
            <Button Content="Load Sprite Sheet" Click="LoadSpriteSheet_Click"/>
            <Button Content="Export to JSON" Margin="10,0,0,0" Click="ExportAnimationsToJson_Click"/>
            <Button Content="Import Animations" Margin="10,0,0,0" Click="ImportAnimationsFromJson_Click"/>
            <Label Content="Frame Width:" Margin="10,0,0,0"/>
            <TextBox x:Name="FrameWidthBox" Width="50" Text="64"/>
            <Label Content="Frame Height:" Margin="10,0,0,0"/>
            <TextBox x:Name="FrameHeightBox" Width="50" Text="64"/>
            <CheckBox x:Name="MirrorSelectBox" Content="Mirror Select" Margin="10,0,0,0" IsChecked="True"/>
            <CheckBox x:Name="ReducedSpriteSet" Content="Reduced Sprite Set" Margin="10,0,0,0" IsChecked="True"/>
        </StackPanel>

        <!-- Animation list panel docked to the left -->
        <StackPanel DockPanel.Dock="Left" Width="245" Margin="10">
            <TextBlock Text="Animations" FontWeight="Bold" Margin="0,0,0,5"/>
            <ListBox x:Name="AnimationList" Height="400" SelectionChanged="AnimationList_SelectionChanged"/>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBox x:Name="NewAnimationNameBox" Width="100" Margin="0,0,5,0"/>
                <Button Content="Add" Click="AddAnimation_Click" Margin="0,0,5,0"/>
                <Button Content="Rename" Click="RenameAnimation_Click" Margin="0,0,0,0"/>
                <Button Content="Remove" Click="RemoveAnimation_Click" Margin="5,0,0,0"/>
            </StackPanel>

            <!-- New rename controls -->
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
               
            </StackPanel>
        </StackPanel>

        <!-- Sprite grid panel docked to the right -->
        <ScrollViewer DockPanel.Dock="Right"
                  Width="800"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  Margin="10">
            <UniformGrid x:Name="FrameGrid"
                     Background="LightGray"
                     Columns="16"/>
        </ScrollViewer>

        <!-- (Optional) Other content fills remaining space on the left -->
        <Border Background="Transparent"/>
    </DockPanel>
</Window>
